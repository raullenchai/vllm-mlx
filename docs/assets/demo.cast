[27.424, "o", "\u001b[1;33m# Step 5: Works with everything\u001b[0m\r\r\n"]
[27.724, "o", "\r\r\n"]
[27.824, "o", "  \u001b[1mTested:\u001b[0m PydanticAI \u00b7 LangChain \u00b7 smolagents\r\r\n"]
[27.924, "o", "         Aider \u00b7 LibreChat \u00b7 Open WebUI\r\r\n"]
[28.024, "o", "         Anthropic SDK \u00b7 Cursor \u00b7 Claude Code\r\r\n"]
[28.024, "o", "\r\r\n"]
[29.224, "o", "  \u001b[1;36mPython:\u001b[0m\r\r\n"]
[29.274, "o", "    from pydantic_ai import Agent\r\r\n"]
[29.324, "o", "    from pydantic_ai.models.openai import OpenAIChatModel\r\r\n"]
[29.374, "o", "    from pydantic_ai.providers.openai import OpenAIProvider\r\r\n"]
[29.424, "o", "\r\r\n"]
[29.474, "o", "    model = OpenAIChatModel(\r\r\n"]
[29.524, "o", "        model_name=\"gemma-4-26b\",\r\r\n"]
[29.574, "o", "        provider=OpenAIProvider(\r\r\n"]
[29.624, "o", "            base_url=\"http://localhost:8000/v1\"))\r\r\n"]
[29.674, "o", "    Agent(model).run_sync(\"Hello!\")\r\r\n"]
[29.674, "o", "\r\r\n"]
[32.874, "o", "\u001b[1;33m# Benchmarks \u2014 Gemma 4 26B 4-bit, Apple Silicon\u001b[0m\r\r\n"]
[33.174, "o", "\r\r\n"]
[33.274, "o", "  Engine        tok/s     vs Ollama\r\r\n"]
[33.374, "o", "  \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500  \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500  \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\r\r\n"]
[33.574, "o", "  \u001b[1;32mRapid-MLX     85 tok/s   1.13x faster\u001b[0m\r\r\n"]
[33.724, "o", "  mlx-vlm       84 tok/s   1.12x\r\r\n"]
[33.874, "o", "  Ollama         75 tok/s   baseline\r\r\n"]
[33.874, "o", "\r\r\n"]
[37.374, "o", "\r\r\n"]
[37.424, "o", "  \u2554\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2557\r\r\n"]
[37.474, "o", "  \u2551                                             \u2551\r\r\n"]
[37.524, "o", "  \u2551  \u001b[1mpip install rapid-mlx\u001b[0m                      \u2551\r\r\n"]
[37.574, "o", "  \u2551  \u001b[1mrapid-mlx serve gemma-4-26b\u001b[0m                \u2551\r\r\n"]
